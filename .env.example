# Chuỗi kết nối PostgreSQL (bắt buộc).
# Supabase: Settings → Database → Connection string → URI (password phải URL-encode).
# Hoặc Postgres tự host: postgres://user:password@host:5432/dbname
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# Chuỗi bí mật ký cookie phiên đăng nhập (đổi thành chuỗi ngẫu nhiên dài).
# BẮT BUỘC khi chạy production — thiếu sẽ lỗi khi đăng nhập.
XBOSS_SECRET="doi-thanh-chuoi-bi-mat-that-dai"

# Mật khẩu tài khoản admin@xboss.vn tạo lần đầu khi DB trống (chỉ production).
# Dev không cần — sẽ tự seed 4 tài khoản mẫu (admin123/pm123/eng123/sub123).
XBOSS_ADMIN_PASSWORD=""

# ===== Email báo cáo trễ hạn hằng ngày (tuỳ chọn) =====
# Bảo vệ endpoint cron /api/cron/daily-report (Vercel Cron tự gửi Bearer token này).
CRON_SECRET=""
# SMTP gửi mail (Gmail: smtp.gmail.com:587 + App Password; hoặc SMTP bất kỳ).
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""           # mặc định: "XBoss" <SMTP_USER>
# Người nhận, phân tách dấu phẩy — bỏ trống = gửi cho mọi Admin + PM trong hệ thống.
REPORT_EMAIL_TO=""
# URL app để chèn link vào email (vd: https://xboss.example.com)
APP_URL=""

# ===== Telegram báo cáo trễ hạn (tuỳ chọn — gửi song song với email) =====
# Tạo bot qua @BotFather → lấy token. Chat ID: thêm bot vào nhóm rồi gọi
# https://api.telegram.org/bot<TOKEN>/getUpdates để xem chat.id (nhiều ID phân tách dấu phẩy).
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
